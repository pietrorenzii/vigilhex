# VigilHex Environment Variables
# Copy this file to .env and fill in your values

# ADS-B Exchange API (free tier at adsbexchange.com)
ADSBX_API_KEY=your_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHANNEL_ID=@your_channel_here

# Database
DATABASE_URL=sqlite:///./vigilhex.db

# Redis
REDIS_URL=redis://localhost:6379

# Alert thresholds
TRANSPONDER_OFF_MINUTES=5
LOITER_ORBITS_THRESHOLD=3
ANOMALY_SCORE_THRESHOLD=0.75
